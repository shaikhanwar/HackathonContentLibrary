{
  "$schema": "internal://hcl/list-schema",
  "description": "SharePoint Online / Microsoft Lists column definitions for the Hackathon Content Library pilot, aligned 1:1 with the app's canonical record shapes in prototype/js/factory.js and the column mapping in prototype/js/csvstore.js. The SharePoint-hosted app (prototype/js/sharepointstore.js) reads and writes these lists via same-origin REST, storing every value as a string, so all columns are Text or Note (no Choice/Number/Lookup type friction). Relationships are kept as business-key text columns (AgencyId, EventId, ...) per the app's join strategy, independent of the SharePoint item Id. This keeps one mapping layer shared with the CSV self-tests. (A future Power Apps / Dataverse path can re-introduce Choice/Number/Lookup/Calculated typing; that is intentionally out of scope for the lean SharePoint-hosted pilot.)",
  "auditing": {
    "summary": "Auditing is provided by SharePoint natively plus an explicit audit-log list for in-app display.",
    "nativeColumns": ["Author (Created By)", "Created", "Editor (Modified By)", "Modified"],
    "versionHistory": "Enable list versioning on every list so each item edit is retained as a restorable version. Recommended: major versions, retain at least 50.",
    "tenantAuditLog": "Microsoft Purview audit logging captures view/edit/delete events at the tenant level (search via Purview > Audit).",
    "inAppDisplay": "The app mirrors this with CreatedBy/Created/ModifiedBy/Modified columns on each record plus an HCLAuditLog list surfaced through the on-page 'Audit' button.",
    "applyTo": ["HCLAgencies", "HCLEvents", "HCLUseCases", "HCLCalendar", "HCLTeams"]
  },
  "listSettings": {
    "versioningEnabled": true,
    "majorVersionLimit": 50,
    "titleNote": "Every list keeps the default Title column. For lists whose record model has no natural title (HCLWinners, HCLAuditLog) the app sets Title to the business key on save.",
    "requiredNote": "Only Title is marked required at the SharePoint level; the app enforces its own required-field rules on the capture forms. This keeps REST creates from being blocked by partially-filled records.",
    "typeNote": "All columns are Text or Note because the app persists string values. Long or multi-value fields (semicolon-joined) use Note; short scalars use Text. Indexed key columns speed up the per-list reconcile on save."
  },
  "lists": [
    {
      "displayName": "HCL Agencies",
      "internalName": "HCLAgencies",
      "description": "State & local agencies / customers.",
      "columns": [
        { "name": "Title", "type": "Text", "required": true, "note": "Agency name (e.g., Metro Buildings Department)" },
        { "name": "AgencyId", "type": "Text", "indexed": true },
        { "name": "ShortName", "type": "Text" },
        { "name": "AgencyType", "type": "Text", "note": "City | County | State | Regional | Federal" },
        { "name": "Region", "type": "Text" },
        { "name": "Jurisdiction", "type": "Text" },
        { "name": "Domain", "type": "Text" },
        { "name": "DMFirstName", "type": "Text", "note": "Decision maker — first name." },
        { "name": "DMLastName", "type": "Text" },
        { "name": "DMJobTitle", "type": "Text" },
        { "name": "DMRole", "type": "Text" },
        { "name": "DMEmail", "type": "Text" },
        { "name": "DMCountry", "type": "Text" },
        { "name": "DMBusinessPhone", "type": "Text" },
        { "name": "RecordStatus", "type": "Text", "note": "Draft | Published | Archived" },
        { "name": "CreatedBy", "type": "Text" },
        { "name": "Created", "type": "Text" },
        { "name": "ModifiedBy", "type": "Text" },
        { "name": "Modified", "type": "Text" }
      ]
    },
    {
      "displayName": "HCL People",
      "internalName": "HCLPeople",
      "description": "Microsoft support staff and champions. Title holds display name; link to a Person column in production.",
      "columns": [
        { "name": "Title", "type": "Text", "required": true, "note": "Full name" },
        { "name": "PersonId", "type": "Text", "indexed": true },
        { "name": "Email", "type": "Text" },
        { "name": "PrimaryOrg", "type": "Text", "note": "CSA | ATU | STU | CSU | Specialist | Field | Agency" },
        { "name": "RoleTitle", "type": "Text" },
        { "name": "HackathonRoles", "type": "Note", "note": "Semicolon-joined roles." },
        { "name": "SolutionAreas", "type": "Note", "note": "Semicolon-joined solution areas." },
        { "name": "ChampionCapability", "type": "Note", "note": "Semicolon-joined champion capabilities." },
        { "name": "Active", "type": "Text", "note": "true | false" }
